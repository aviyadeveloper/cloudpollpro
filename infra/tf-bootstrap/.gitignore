
# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude override files as they are usually used to override resources locally
*.tfvars
*.tfvars.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan output
*.tfplan

# Security: Never commit state files (may contain resource metadata)
# Note: No secrets stored in state with role-based approach
../*/.terraform/
../*/terraform.tfstate*
